# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase connection pooler URL (port 6543, not 5432 — required for serverless)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test-mode secret key (sk_test_…). Production keys (sk_live_…) will throw.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. Get from `stripe listen` (dev) or Stripe Dashboard (prod).
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform management fee in basis points. 800 = 8%, 500 = 5%, etc.
STRIPE_CONNECT_LANDLORD_PLATFORM_FEE_BPS=800

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cron security ─────────────────────────────────────────────────────────────
# Random secret used to protect /api/cron/* endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-random-secret

# ── App URL ───────────────────────────────────────────────────────────────────
# Public base URL. Defaults to http://localhost:3000 if omitted.
NEXT_PUBLIC_APP_URL=http://localhost:3000
